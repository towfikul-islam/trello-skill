# Trello raw-API skill — credentials
# Copy this file to  ~/.claude/.trello.env  and fill in your own values.
# This file (the .example) is safe to commit; ~/.claude/.trello.env is NOT — keep it private.

# From https://trello.com/power-ups/admin/new  ->  API key page  (see README)
TRELLO_KEY=PUT_YOUR_KEY_HERE
TRELLO_TOKEN=PUT_YOUR_TOKEN_HERE

# Your Trello member ID. After KEY+TOKEN are set, run:
#   source ~/.claude/skills/trello/trello.sh && tr_get "/1/members/me?fields=id,username"
# then paste the "id" value here.
TRELLO_MEMBER_ID=PUT_YOUR_MEMBER_ID_HERE
